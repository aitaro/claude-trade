trade.aitaro.dev {
    # oauth2-proxy routes (認証不要)
    @oauth2 path /oauth2/*
    handle @oauth2 {
        reverse_proxy localhost:4180
    }

    # それ以外は認証必須
    handle {
        forward_auth localhost:4180 {
            uri /oauth2/auth
            header_up X-Forwarded-For {remote_host}
            copy_headers X-Auth-Request-User X-Auth-Request-Email

            @unauthorized status 401
            handle_response @unauthorized {
                redir https://trade.aitaro.dev/oauth2/start?rd={uri}
            }
        }

        handle /api/* {
            uri strip_prefix /api
            reverse_proxy localhost:3100
        }

        handle {
            root * /opt/claude-trade/packages/web/dist
            try_files {path} /index.html
            file_server
        }
    }

    log {
        output file /var/log/caddy/access.log
        format json
    }
}

docs.trade.aitaro.dev {
    # 同じ oauth2-proxy で認証
    @oauth2 path /oauth2/*
    handle @oauth2 {
        reverse_proxy localhost:4180
    }

    handle {
        forward_auth localhost:4180 {
            uri /oauth2/auth
            header_up X-Forwarded-For {remote_host}
            copy_headers X-Auth-Request-User X-Auth-Request-Email

            @unauthorized status 401
            handle_response @unauthorized {
                redir https://docs.trade.aitaro.dev/oauth2/start?rd={uri}
            }
        }

        root * /opt/claude-trade/docs/.vitepress/dist
        try_files {path} {path}.html /404.html
        file_server
    }
}
